# ============================================================
# vmqfox-epay-adapter 环境变量模板
# 用法：cp .env.example .env，然后填入真实值。deploy.sh 会自动生成随机密钥。
# .env 文件不会进 git（被 .gitignore 屏蔽）。
# ============================================================

# === 必填：密钥配置 ===

# V免签 通讯密钥（适配器 ↔ V免签 之间的认证）
# 必须与 V免签 后台「系统设置 → 通讯密钥」保持一致。
# deploy.sh 会自动生成并同步到 V免签 数据库。
VMQ_KEY=

# 易支付协议商户 ID（适配器对外暴露给 Sum API/NewAPI）
# 上游商户系统的「商户 ID」字段填这个值。可以任意非空字符串。
EPAY_PID=1001

# 易支付协议密钥（适配器 ↔ 上游商户系统之间的认证）
# 上游商户系统的「API 密钥」字段填这个值。
# 注意：这是给 Sum API 看的密钥，跟 VMQ_KEY 不是同一个东西。
EPAY_KEY=

# === 选填：访问地址 ===

# V免签 前端访问 URL（用户支付时的浏览器跳转地址）
# 上云后改成你的公网 URL，例如 http://your-ip:3006 或 https://pay.yourdomain.com
APP_FRONTEND_URL=http://localhost:3006

# === 选填：端口（一般不动） ===
# FRONTEND_PORT=3006
# BACKEND_PORT=8000
# ADAPTER_PORT=8888
# MYSQL_PORT=3306
# REDIS_PORT=6380

# === 选填：MySQL root 密码（生产环境强烈建议改） ===
# MYSQL_ROOT_PASSWORD=vmqfox123
